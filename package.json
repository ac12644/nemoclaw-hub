{
  "name": "agenthub",
  "version": "0.2.0",
  "description": "General-purpose sandboxed AI agent management platform with workflow engine",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:client": "cd client && npx vite",
    "build:server": "tsc",
    "build:client": "cd client && npx vite build",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "test": "tsx --test test/hub-*.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "better-sqlite3": "^11.9.1",
    "fastify": "^5.3.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ac12644/nemoclaw-hub.git"
  }
